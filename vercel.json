{
  "rewrites": [
    { "source": "/", "destination": "/index.html" }
  ],
  "functions": {
    "api/cron/dispatch-tick.js": { "maxDuration": 60 },
    "api/dispatch/trigger.js":   { "maxDuration": 60 },
    "api/uazapi/connect.js":     { "maxDuration": 30 },
    "api/webhook/uazapi.js":     { "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
